# Telegram bot token (@BotFather dan olinadi)
BOT_TOKEN=123456:ABC-DEF...

# Admin foydalanuvchi ID lari (vergul bilan ajratilgan)
ADMIN_IDS=123456789,987654321

# JSON fayllar saqlanadigan papka (lokalda ./data, Railwayda /app/data)
DATA_DIR=./data

# Vaqtinchalik yuklab olingan videolar papkasi
DOWNLOADS_DIR=./downloads

# Opsional: cookies.txt fayl yo'li (default: DATA_DIR/cookies.txt).
# Odatda bo'sh qoldiriladi — cookies YTDLP_COOKIES_B64 orqali beriladi.
YTDLP_COOKIES=

# Opsional: cookies.txt faylining base64 ko'rinishi (YouTube bot-check yechimi).
# Railway Variables bir qatorli qiymat kutgani uchun base64 ishlatamiz.
# Bot ishga tushganda dekodlanib DATA_DIR/cookies.txt ga yoziladi.
YTDLP_COOKIES_B64=

# Opsional: yt-dlp binary yo'li (default: "./bin/yt-dlp").
# Lokalda tizimdagi yt-dlp'dan foydalanish uchun "yt-dlp" deb yozing.
YTDLP_PATH=./bin/yt-dlp

# Opsional: gallery-dl binary yo'li (rasm yuklash uchun, default: "./bin/gallery-dl")
GALLERY_DL_PATH=./bin/gallery-dl

# Opsional: ffmpeg binary (default: "ffmpeg") — musiqa aniqlashda audio kesish uchun
FFMPEG_PATH=ffmpeg

# Opsional: ACRCloud (Shazam kabi ovozdan musiqa aniqlash).
# Uchalasi ham bo'sh bo'lsa — funksiya o'chiq bo'ladi.
ACR_HOST=
ACR_ACCESS_KEY=
ACR_ACCESS_SECRET=
